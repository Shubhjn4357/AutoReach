{
  "name": "autoreach",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "web:dev": "tsx web/server.mts",
    "web:build": "next build web",
    "web:start": "NODE_ENV=production tsx web/server.mts",
    "mobile:start": "expo start mobile",
    "mobile:ios": "expo start mobile --ios",
    "mobile:android": "expo start mobile --android",
    "mobile:android:prod": "cd mobile && eas build --platform android --profile production",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "@whiskeysockets/baileys": "7.0.0-rc13",
    "bullmq": "^5.8.0",
    "clsx": "^2.1.0",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.2",
    "expo-dev-client": "~56.0.20",
    "express": "^5.2.1",
    "ioredis": "^5.4.1",
    "lucide-react": "^0.300.0",
    "next": "^15.0.0",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@react-native/metro-config": "0.85.3",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.43",
    "@types/qrcode": "^1.5.6",
    "@types/react": "~19.2.17",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.5.0",
    "postcss": "^8.4.0",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "resolutions": {
    "lightningcss": "1.30.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@whiskeysockets/baileys",
      "esbuild",
      "msgpackr-extract",
      "protobufjs",
      "sharp",
      "whatsapp-rust-bridge"
    ],
    "patchedDependencies": {
      "whatsapp-rust-bridge@0.5.4": "patches/whatsapp-rust-bridge@0.5.4.patch"
    }
  }
}
