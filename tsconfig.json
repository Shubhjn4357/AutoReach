{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "types": ["node"],
    "paths": {
      "@/*": [
        "./web/*"
      ],
      "@/shared/*": [
        "./shared/*"
      ],
      "@/web/*": [
        "./web/*"
      ],
      "@/mobile/*": [
        "./mobile/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "OpenWA",
    "node_modules",
    "dist",
    "mobile",
    "web/src",
    "openwa.ts"
  ],
  "extends": "expo/tsconfig.base"
}
