{
  "cli": {
    "version": ">= 9.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "simulator": {
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "keystorePath": "./key.keystore",
        "keystorePassword": "${GOOGLE_PLAY_KEYSTORE_PASSWORD}",
        "keyAlias": "${GOOGLE_PLAY_KEY_ALIAS}",
        "keyPassword": "${GOOGLE_PLAY_KEY_PASSWORD}"
      }
    }
  }
}
